{
  "compilerOptions": {
    "target": "ES2023",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "allowSyntheticDefaultImports": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@prisma/*": [
        "prisma/schema/*"
      ],
      "@app/*": [
        "src/app/*"
      ],
      "@cm/*": [
        "src/cm/*"
      ],
      "@shadcn/*": [
        "src/cm/shadcn/*"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "next.config.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.dump",
    "public/**/*",
    "scripts/**/*",
    ".next/cache/**/*",
    ".next/server/**/*",
    ".next/static/**/*",
    "dist",
    "build",
    "**/*.spec.ts",
    "**/*.test.ts",
    "coverage",
    "**/scheme-json-export.js",
    "src/app/(apps)/KM/**/*",
    "src/app/(apps)/aidocument/**/*",
    "src/app/(apps)/common/**/*",
    "src/app/(apps)/counseling/**/*",
    "src/app/(apps)/curious/**/*",
    "src/app/(apps)/dental/**/*",
    "src/app/(apps)/earth/**/*",
    "src/app/(apps)/generated/**/*",
    "src/app/(apps)/image-captioner/**/*",
    "src/app/(apps)/kaigoshoku/**/*",
    "src/app/(apps)/kickswrap/**/*",
    "src/app/(apps)/migrations/**/*",
    "src/app/(apps)/portal/**/*",
    "src/app/(apps)/recipeCalculator/**/*",
    "src/app/(apps)/sbm/**/*",
    "src/app/(apps)/stock/**/*",
    "src/app/(apps)/synesthesia/**/*",
    "src/app/(apps)/tmp/**/*",
    "src/app/(apps)/training/**/*",
    "src/app/(apps)/yamanokai/**/*"
  ]
}