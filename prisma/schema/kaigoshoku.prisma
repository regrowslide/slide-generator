// ======================================
// 介護食管理システム用スキーマ
// プレフィックス: Kg (Kaigo-shoku)
// ======================================

// 施設/取引先マスタ
model KgFacilityMaster {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  code          String  @unique
  name          String
  contactMethod String  @default("CSV") // CSV, FAX, Email
  address       String?
  phone         String?
  email         String?
  isActive      Boolean @default(true)

  KgOrder KgOrder[]
}

// 食事形態マスタ
model KgDietTypeMaster {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  code        String  @unique // regular, kizami, kiwamekizami, mixer
  name        String // 常食, 刻み食, 極刻み食, ミキサー食
  description String?
  colorClass  String? // Tailwind CSSクラス

  KgOrderLine      KgOrderLine[]
  KgProductionItem KgProductionItem[]
}

// 日付献立
model KgDailyMenu {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  menuDate        DateTime @unique @db.Date
  totalVegetableG Float? // 1日合計野菜量(g)
  pfc             String? // P:F:C比率 "15:32:50"
  note            String?

  KgMealSlot KgMealSlot[]
}

// 食事区分（朝食、昼食、昼間食、夕食）
model KgMealSlot {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  dailyMenuId  Int
  mealType     String // breakfast, lunch, snack, dinner
  mealTypeName String // 朝食, 昼食, 昼間食, 夕食

  // 栄養素合計
  totalEnergy     Float?
  totalProtein    Float?
  totalFat        Float?
  totalCarb       Float?
  totalSodium     Float?
  totalSalt       Float?
  totalVegetableG Float?

  KgDailyMenu  KgDailyMenu    @relation(fields: [dailyMenuId], references: [id], onDelete: Cascade)
  KgMenuRecipe KgMenuRecipe[]

  @@unique([dailyMenuId, mealType])
}

// 献立レシピ（自己参照で階層管理: レシピ → サブレシピ → 食材）
model KgMenuRecipe {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  mealSlotId     Int
  parentRecipeId Int? // 親レシピID（サブレシピの場合）
  code           String
  name           String
  category       String? // 主菜, 副菜, 主食, 汁物, デザート

  unitWeight Float? // 1人前の重量
  unit       String @default("g")

  // 栄養素合計
  totalEnergy     Float?
  totalProtein    Float?
  totalFat        Float?
  totalCarb       Float?
  totalSodium     Float?
  totalSalt       Float?
  totalVegetableG Float?

  KgMealSlot         KgMealSlot           @relation(fields: [mealSlotId], references: [id], onDelete: Cascade)
  ParentRecipe       KgMenuRecipe?        @relation("RecipeHierarchy", fields: [parentRecipeId], references: [id])
  ChildRecipes       KgMenuRecipe[]       @relation("RecipeHierarchy")
  KgRecipeIngredient KgRecipeIngredient[]
  KgOrderLine        KgOrderLine[]
  KgProductionItem   KgProductionItem[]
}

// レシピ食材
model KgRecipeIngredient {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  menuRecipeId       Int
  ingredientMasterId Int? // RcIngredientMasterへの参照（リンク済みの場合）

  ingredientCode   String // 食品標準成分表コード
  ingredientName   String
  amountPerServing Float // 1人前の使用量
  unit             String @default("g")

  // 栄養素（計算値）
  energy     Float?
  protein    Float?
  fat        Float?
  carb       Float?
  sodium     Float?
  salt       Float?
  vegetableG Float?

  KgMenuRecipe       KgMenuRecipe        @relation(fields: [menuRecipeId], references: [id], onDelete: Cascade)
  RcIngredientMaster RcIngredientMaster? @relation(fields: [ingredientMasterId], references: [id])
}

// 受注ヘッダー
model KgOrder {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  facilityId   Int?
  orderDate    DateTime @db.Date // 受注日
  deliveryDate DateTime @db.Date // 配送日
  status       String   @default("pending") // pending, confirmed, processing, completed
  sourceType   String   @default("CSV") // CSV, FAX, Manual
  ocrImageUrl  String? // FAX画像URL
  note         String?

  KgFacilityMaster KgFacilityMaster? @relation(fields: [facilityId], references: [id])
  KgOrderLine      KgOrderLine[]
}

// 受注明細
model KgOrderLine {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  orderId      Int
  mealType     String // breakfast, lunch, dinner
  dietTypeId   Int
  menuRecipeId Int? // リンク済みの場合

  rawName  String? // OCR等から取得した生データ
  quantity Int // 食数

  alert       String? // アラート（数量異常等）
  status      String    @default("pending") // pending, confirmed, issue
  confirmedAt DateTime?

  KgOrder          KgOrder           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  KgDietTypeMaster KgDietTypeMaster  @relation(fields: [dietTypeId], references: [id])
  KgMenuRecipe     KgMenuRecipe?     @relation(fields: [menuRecipeId], references: [id])
}

// 製造バッチ
model KgProductionBatch {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  productionDate DateTime @db.Date
  mealType       String // breakfast, lunch, dinner
  status         String   @default("planned") // planned, in_progress, completed

  KgProductionItem     KgProductionItem[]
  KgRequiredIngredient KgRequiredIngredient[]

  @@unique([productionDate, mealType])
}

// 製造品目
model KgProductionItem {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  productionBatchId Int
  menuRecipeId      Int
  dietTypeId        Int
  totalQuantity     Int // 製造予定数
  completedQuantity Int    @default(0) // 製造完了数
  status            String @default("pending") // pending, in_progress, completed

  KgProductionBatch KgProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  KgMenuRecipe      KgMenuRecipe      @relation(fields: [menuRecipeId], references: [id])
  KgDietTypeMaster  KgDietTypeMaster  @relation(fields: [dietTypeId], references: [id])
}

// 必要食材計算結果
model KgRequiredIngredient {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  productionBatchId  Int
  ingredientMasterId Int? // RcIngredientMasterへの参照
  ingredientCode     String
  ingredientName     String
  totalAmount        Float // 必要総量
  unit               String
  estimatedCost      Float? // 予想原価

  KgProductionBatch  KgProductionBatch   @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  RcIngredientMaster RcIngredientMaster? @relation(fields: [ingredientMasterId], references: [id])
}
