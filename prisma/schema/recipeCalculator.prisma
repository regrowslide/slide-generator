// 食品製造原価計算システム用スキーマ
// プロジェクトルール準拠：リレーション名は対象テーブルと同一、大文字で開始
// 外部キーは小文字で開始、{modelName}Id
// 日付データは at をつける

// 原材料マスタ
model RcIngredientMaster {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  name     String // 食材名
  price    Float  // キロ単価（円/kg）
  yield    Float  // 歩留まり（%）
  category String // 分類（野菜、肉類、調味料等）
  supplier String // 仕入れ先

  // リレーション
  RcRecipeIngredient RcRecipeIngredient[]
}

// レシピ
model RcRecipe {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  name    String // レシピ名
  status  String @default("draft") // draft, analyzing, completed

  // 製造パラメータ
  lossRate       Float @default(5) // 製造ロス率（%）
  packWeightG    Float @default(200) // 1パックあたりの充填量（g）
  packagingCost  Float @default(30) // 包材費（円/パック）
  processingCost Float @default(50) // 加工費（円/パック）
  profitMargin   Float @default(200) // 目標粗利額（円/パック）

  // 計算結果キャッシュ
  totalMaterialCost   Float? // 原材料費合計
  totalWeightKg       Float? // 原材料総重量
  productionWeightKg  Float? // 製造可能重量
  packCount           Int? // 製造パック数
  materialCostPerPack Float? // 1パックあたり原材料費
  totalCostPerPack    Float? // 1パックあたり製造原価
  sellingPrice        Float? // 見積提示価格

  // 元ファイル情報
  sourceType     String? // text, image, pdf
  sourceFileName String?
  sourceFileUrl  String?

  // リレーション
  RcRecipeIngredient RcRecipeIngredient[]
}

// レシピ内食材
model RcRecipeIngredient {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  // レシピへの紐付け
  recipeId Int
  RcRecipe RcRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // マスタへの紐付け（nullの場合は外部検索データ）
  ingredientMasterId   Int?
  RcIngredientMaster   RcIngredientMaster? @relation(fields: [ingredientMasterId], references: [id], onDelete: SetNull)

  // 食材情報
  name         String // 現在の表示名（マスタ名 or 解析された名前）
  originalName String? // OCR解析時の元表記

  // 分量・単位
  amount   Float // レシピ記載の数値
  unit     String // レシピ記載の単位（g, kg, l, ml, cc等）
  weightKg Float  @default(0) // 計算用換算重量（kg）

  // 単価・コスト
  pricePerKg Float @default(0) // 適用単価（円/kg）
  yieldRate  Float @default(100) // 適用歩留まり（%）
  cost       Float @default(0) // 原価小計（円）

  // メタデータ
  isExternal  Boolean @default(false) // 外部検索データかどうか
  source      String  @default("手動入力") // データソース名
  status      String  @default("done") // pending, searching, done, error
  matchReason String? // マスタ照合の理由

  // 外部検索結果の詳細
  externalProductName String? // 外部検索で見つかった商品名
  externalProductId   String? // 外部検索の商品ID
  externalProductUrl  String? // 外部検索の商品URL
  externalPrice       Float?  // 外部検索の販売価格（円）
  externalWeight      Float?  // 外部検索の重量（g）
  externalWeightText  String? // 外部検索の重量表示テキスト
}
