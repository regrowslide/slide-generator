// LifeOS - 生活ログ管理システム
// PostgreSQL用Prismaスキーマ

model LifeOSCategory {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt()
  sortOrder Float     @default(0)

  name        String  @unique
  description String?
  schema      Json // 拡張スキーマ（label, displayType, unit等を含む）
  archetypes  Json // アーキタイプ配列（例: ["attribute-card", "metric-tracker"]）

  logs LifeOSLog[]
}

model LifeOSLog {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt()
  sortOrder Float     @default(0)

  // archetype String  // 削除：カテゴリのarchetypesを参照するため
  // schema   Json      // 削除：カテゴリのスキーマを参照するため
  data        Json // 実データのみ
  description String? // ログの説明（AIが生成）

  category   LifeOSCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId Int
}
