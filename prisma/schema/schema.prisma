datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

model Department {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt()
  sortOrder Float     @default(0)

  code  String? @unique
  name  String
  color String?

  User User[]
}

model Store {
  id        Int       @id @default(autoincrement())
  code      Int       @unique
  createdAt DateTime  @default(now())
  active    Boolean   @default(true)
  sortOrder Float     @default(0)
  name      String
  updatedAt DateTime? @updatedAt

  tel     String?
  fax     String?
  address String?

  User User[]
}

model User {
  id            String    @id @default(uuid())
  code          String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime? @default(now()) @updatedAt()
  sortOrder     Float     @default(0)
  // active        Boolean   @default(true)
  hiredAt       DateTime?
  retiredAt     DateTime?
  transferredAt DateTime?
  yukyuCategory String?   @default("A")

  name     String
  kana     String?
  email    String? @unique
  password String? @default("999999")

  type String?

  role String @default("user")

  tempResetCode        String?
  tempResetCodeExpired DateTime?
  schoolId             Int?
  rentaStoreId         Int?
  type2                String?
  shopId               Int?
  membershipName       String?
  damageNameMasterId   Int?
  color                String?
  app                  String?
  apps                 String[]

  lineUserId String? @unique

  // better-auth
  emailVerified Boolean   @default(false)
  image         String?
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?

  employeeCode String? @unique
  phone        String?

  avatar String?

  bcc String?

  UserRole UserRole[]
  Session  Session[]
  Account  Account[]

  SbmReservation        SbmReservation[]
  SbmDeliveryAssignment SbmDeliveryAssignment[]

  // トレーニングアプリ リレーション
  ExerciseMaster              ExerciseMaster[]
  WorkoutLog                  WorkoutLog[]
  SbmReservationChangeHistory SbmReservationChangeHistory[]
  CounselingStore             CounselingStore?              @relation(fields: [counselingStoreId], references: [id])
  counselingStoreId           Int?
  CounselingSlot              CounselingSlot[]

  Store   Store? @relation(fields: [storeId], references: [id])
  storeId Int?

  // yamanokai
  YamanokaiEventAsCL            YamanokaiEvent[]      @relation("YamanokaiEventCL")
  YamanokaiEventAsSL            YamanokaiEvent[]      @relation("YamanokaiEventSL")
  YamanokaiAttendance           YamanokaiAttendance[]
  YamanokaiAttendanceAsApprover YamanokaiAttendance[] @relation("AttendanceApprover")
  department                    Department?           @relation(fields: [departmentId], references: [id])
  departmentId                  Int?

  // dental
  DentalClinic               DentalClinic?       @relation(fields: [dentalClinicId], references: [id])
  dentalClinicId             Int?
  DentalExaminationDoctor    DentalExamination[] @relation("ExaminationDoctor")
  DentalExaminationHygienist DentalExamination[] @relation("ExaminationHygienist")

  // regrow
  rgStoreId             Int?
  RgStoreRg             RgStore?            @relation("RgUserStore", fields: [rgStoreId], references: [id])
  RgStaffRecordUser     RgStaffRecord[]     @relation("RgStaffRecordUser")
  RgStaffManualDataUser RgStaffManualData[] @relation("RgStaffManualDataUser")

  // kids
  KidsChildUser KidsChild[] @relation("KidsChildUser")
}

// better-auth セッションテーブル
model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@map("session")
}

// better-auth アカウントテーブル
model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

// better-auth メール認証テーブル
model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model ReleaseNotes {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt()
  sortOrder Float     @default(0)

  rootPath         String
  title            String?
  msg              String
  imgUrl           String?
  confirmedUserIds String[]
}

model Tokens {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt()
  sortOrder Float     @default(0)

  name      String    @unique
  token     String
  expiresAt DateTime?
}

model GoogleAccessToken {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt()
  sortOrder Float     @default(0)

  email         String    @unique
  access_token  String?
  refresh_token String?
  scope         String?
  token_type    String?
  id_token      String?
  expiry_date   DateTime?
  tokenJSON     String?
}

model RoleMaster {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  name        String     @unique
  description String?
  color       String?
  apps        String[]
  UserRole    UserRole[]
}

model UserRole {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  User         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  RoleMaster   RoleMaster @relation(fields: [roleMasterId], references: [id], onDelete: Cascade)
  roleMasterId Int

  @@unique([userId, roleMasterId], name: "userId_roleMasterId_unique")
}

model ChainMethodLock {
  id        Int       @id @default(autoincrement())
  isLocked  Boolean   @default(false)
  expiresAt DateTime?
  updatedAt DateTime  @updatedAt
}

model Calendar {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt()
  sortOrder Float     @default(0)

  date DateTime @unique

  holidayType String @default("出勤")
}

model CronExecutionLog {
  id           Int       @id @default(autoincrement())
  batchId      String // バッチ識別子
  batchName    String // バッチ名称
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  duration     Int? // 実行時間（ミリ秒）
  status       String // 'success' | 'failure' | 'running'
  errorMessage String? // エラーメッセージ
  result       String? // 実行結果（JSON文字列、簡略化）
  createdAt    DateTime  @default(now())

  @@index([batchId])
  @@index([startedAt])
  @@index([status])
}
