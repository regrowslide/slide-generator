// Kids アプリ用スキーマ
// 子どもの生活習慣ルーチン管理「できたよ！」

model KidsChild {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  name  String // 子どもの名前
  emoji String @default("👶") // アイコン絵文字

  userId String // 保護者のUser FK

  User             User              @relation("KidsChildUser", fields: [userId], references: [id], onDelete: Cascade)
  KidsCategory     KidsCategory[]
  KidsRoutineLog   KidsRoutineLog[]
  KidsAchievement  KidsAchievement[]
  KidsStreak       KidsStreak?
}

model KidsCategory {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  name       String // カテゴリ名（あさ、ひる、よる等）
  emoji      String // カテゴリ絵文字
  isArchived Boolean @default(false)

  childId Int

  KidsChild   KidsChild     @relation(fields: [childId], references: [id], onDelete: Cascade)
  KidsRoutine KidsRoutine[]
}

model KidsRoutine {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)

  name       String // ルーチン名（ひらがな）
  emoji      String // 未完了時アイコン
  sticker    String // 完了時バッジ
  isArchived Boolean @default(false)

  categoryId Int

  KidsCategory   KidsCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  KidsRoutineLog KidsRoutineLog[]
}

model KidsRoutineLog {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())

  routineId   Int
  childId     Int
  date        String // "YYYY-MM-DD" (JST)
  completedAt DateTime @default(now())

  KidsRoutine KidsRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  KidsChild   KidsChild   @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([routineId, childId, date])
}

model KidsAchievement {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  childId Int
  sticker String // バッジ絵文字
  name    String // アイテム名
  date    String // "YYYY-MM-DD"

  KidsChild KidsChild @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model KidsStreak {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  childId           Int     @unique
  currentStreak     Int     @default(0)
  longestStreak     Int     @default(0)
  lastCompletedDate String? // "YYYY-MM-DD"

  KidsChild KidsChild @relation(fields: [childId], references: [id], onDelete: Cascade)
}
