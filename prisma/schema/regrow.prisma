// Regrowアプリ用スキーマ
// 月次業績レポート管理（店舗・スタッフ・KPI）

model RgStore {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  sortOrder Float     @default(0)
  name      String // '港北店', '青葉店', '中央店'
  isActive  Boolean   @default(true)

  RgUserList        User[]              @relation("RgUserStore")
  RgStoreKpi        RgStoreKpi[]
  RgStoreTotals     RgStoreTotals[]
  RgStaffRecord     RgStaffRecord[]
  RgStaffManualData RgStaffManualData[]
  RgStaffMenuRecord RgStaffMenuRecord[]
}

model RgMonthlyReport {
  id               Int       @id @default(autoincrement())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime? @updatedAt
  sortOrder        Float     @default(0)
  yearMonth        String // "2026-02"
  importedAt       DateTime?
  importedFileName String?
  reportUpdatedAt  DateTime? // 手動設定の最終更新日時（UTC保存）

  RgStaffRecord     RgStaffRecord[]
  RgStoreTotals     RgStoreTotals[]
  RgStoreKpi        RgStoreKpi[]
  RgStaffManualData RgStaffManualData[]
  RgCustomerVoice   RgCustomerVoice[]
  RgStaffMenuRecord RgStaffMenuRecord[]

  @@unique([yearMonth])
}

model RgStaffRecord {
  id               Int       @id @default(autoincrement())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime? @updatedAt
  sortOrder        Float     @default(0)
  monthlyReportId  Int
  staffName        String // スタッフ名（直接保存）
  userId           String? // Userとの紐付け（任意）
  storeId          Int
  rank             Int
  sales            Float
  customerCount    Int
  newCustomerCount Int
  nominationCount  Int
  unitPrice        Float

  RgMonthlyReport RgMonthlyReport @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)
  User            User?           @relation("RgStaffRecordUser", fields: [userId], references: [id], onDelete: SetNull)
  RgStore         RgStore         @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model RgStoreTotals {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt
  sortOrder       Float     @default(0)
  monthlyReportId Int
  storeId         Int
  sales           Float
  customerCount   Int
  nominationCount Int
  unitPrice       Float

  RgMonthlyReport RgMonthlyReport @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)
  RgStore         RgStore         @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model RgStoreKpi {
  id                  Int       @id @default(autoincrement())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime? @updatedAt
  sortOrder           Float     @default(0)
  monthlyReportId     Int
  storeId             Int
  utilizationRate     Float?
  returnRate          Float?
  csRegistrationCount Int?
  googleReviewCount   Int? // Google口コミ獲得数
  comment             String    @default("")

  RgMonthlyReport RgMonthlyReport @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)
  RgStore         RgStore         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([monthlyReportId, storeId])
}

model RgStaffManualData {
  id                  Int       @id @default(autoincrement())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime? @updatedAt
  sortOrder           Float     @default(0)
  monthlyReportId     Int
  staffName           String // スタッフ名（直接保存）
  storeId             Int // 店舗FK
  userId              String? // Userとの紐付け（任意）
  utilizationRate     Float?
  proposalRate        Float? // 提案力実施率 (%)
  csRegistrationCount Int?
  googleReviewCount   Int? // Google口コミ獲得数
  targetSales         Int? // 目標売上（円単位）

  RgMonthlyReport RgMonthlyReport @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)
  User            User?           @relation("RgStaffManualDataUser", fields: [userId], references: [id], onDelete: SetNull)
  RgStore         RgStore         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([monthlyReportId, staffName, storeId])
}

model RgCustomerVoice {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt
  sortOrder       Float     @default(0)
  monthlyReportId Int
  content         String    @default("")

  RgMonthlyReport RgMonthlyReport @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)

  @@unique([monthlyReportId])
}

model RgStaffMenuRecord {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt
  monthlyReportId Int
  staffName       String
  storeId         Int
  menuCategory    String // 'もみほぐし' | 'タイ古式マッサージ' | 'バリ式リンパマッサージ' | 'オプション' | 'その他'
  sales           Float
  customerCount   Int
  ratio           Float // 0.0-1.0（対応客数に対する比率）
  unitPrice       Float

  RgMonthlyReport RgMonthlyReport @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)
  RgStore         RgStore         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([monthlyReportId, staffName, storeId, menuCategory])
}
